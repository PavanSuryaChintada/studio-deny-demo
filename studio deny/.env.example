# Copy this file to `.env` and replace every placeholder with values from:
# Supabase → Project Settings → Database → Connection string
#
# Do NOT leave the words USER, PASSWORD, or example hostnames in the URL — Prisma will try
# to connect to a server literally named "HOST" and fail with P1001.
#
# Password special characters must be URL-encoded in the connection string:
#   @ -> %40   # -> %23   $ -> %24
#
# Example: if your password is  myP@ss#word$1  use  myP%40ss%23word%241

# Transaction pooler (port 6543) — good default for app + Prisma with pgbouncer
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_ENCODED_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session mode / direct (port 5432) — used by Prisma for migrations and `db push`
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_ENCODED_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
